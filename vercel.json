{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "marketing-ai",
  "buildCommand": "echo Pre-build Flutter web with scripts/build_web_release.ps1 or .sh, then deploy.",
  "outputDirectory": "build/web",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
