# ============================================================
#  Marketing AI – Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to source control.
# ============================================================

# --- AI Providers ---
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...

# Default provider: "openai" or "claude"
AI_PROVIDER=openai

# Model overrides (optional — defaults shown below)
# OPENAI_MODEL=gpt-5.2
# CLAUDE_MODEL=claude-sonnet-4-5

# --- App ---
APP_ENV=production           # development | production

# Deployed Flutter web URL (used for CORS):
# FRONTEND_URL=https://your-app.web.app
# Additional origins (comma-separated):
# CORS_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=*

# --- Database ---
# Render provides this automatically. Format for local dev:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/marketing_ai
# (also accepts postgres:// and postgresql:// — the driver converts it automatically)
DATABASE_URL=

# --- Auth (Firebase Admin — required for token verification) ---
# FIREBASE_PROJECT_ID=marketingai-cf01a
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}   # Render: paste full JSON
# FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json  # Local dev alternative
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
